# ==============================================================================
# EMPLOEE MANAGEMENT SYSTEM - CONFIGURACIÓN DE ENTORNO
# ==============================================================================
# Instrucciones:
# 1. Copia este archivo y nómbralo como '.env'
# 2. Configura los valores según tu entorno local
# ==============================================================================

# BASE DE DATOS
SPRING_DB_URL=jdbc:postgresql://localhost:5432/bd_employee_management_system_lta
SPRING_DB_USERNAME=tu_usuario_aqui
SPRING_DB_PASSWORD=tu_contraseña_aqui

# PERFIL/SERVIDOR
# Valores posibles: local, dev, prod
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=9090
SERVER_SERVLET_CONTEXT_PATH=/employee-management-system